<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>랜덤 뽑기</title>
  <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css">
  <style>
    :root{
      --bg:#eef1f8;
      --bg-2:#f7f9fd;
      --card:#ffffff;
      --card-line:#e3e7f1;
      --text:#1b1f33;
      --muted:#8a90a8;
      --blue:#2f6bff;
      --pink:#ff4d8d;
      --amber:#ff9f1c;
      --field:#f5f7fc;
      --font:"Pretendard","Pretendard Variable",-apple-system,BlinkMacSystemFont,system-ui,sans-serif;
    }

    *{box-sizing:border-box}
    html,body{margin:0;padding:0}
    body{
      font-family:var(--font);
      color:var(--text);
      min-height:100vh;
      background:
        radial-gradient(1100px 650px at 8% -8%, rgba(47,107,255,.14), transparent 58%),
        radial-gradient(1000px 650px at 100% 0%, rgba(255,77,141,.13), transparent 55%),
        radial-gradient(900px 800px at 50% 118%, rgba(255,159,28,.12), transparent 60%),
        linear-gradient(180deg,var(--bg),var(--bg-2));
      background-attachment:fixed;
    }

    /* ── 상단 바 ───────────────────────────── */
    .topbar{
      position:sticky;top:0;z-index:50;
      backdrop-filter:blur(14px);
      background:linear-gradient(180deg, rgba(255,255,255,.92), rgba(255,255,255,.72));
      border-bottom:1px solid var(--card-line);
    }
    .topbar-inner{
      max-width:1180px;margin:0 auto;
      padding:15px 22px;
      display:flex;align-items:center;gap:12px;flex-wrap:wrap;
    }
    .brand{display:flex;align-items:center;gap:18px;margin-right:auto}
    .brand .badge{
      flex:none;width:46px;height:46px;border-radius:14px;
      background:linear-gradient(135deg,var(--blue),#7a5cff 55%,var(--pink));
      display:grid;place-items:center;
      box-shadow:0 8px 20px rgba(47,107,255,.32);
      animation:float 3.4s ease-in-out infinite;
    }
    .brand .badge svg{width:25px;height:25px;display:block}
    .brand h1{font-size:22px;font-weight:900;letter-spacing:-.03em;margin:0;line-height:1.15}
    .brand span{color:var(--muted);font-size:12.5px;font-weight:500}

    /* 공정성용 시간 박스 */
    .clock-box{
      display:flex;flex-direction:column;gap:1px;
      padding:8px 16px;border-radius:12px;
      border:1px solid var(--card-line);background:rgba(255,255,255,.7);
      line-height:1.25;
    }
    .clock-label{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:-.01em}
    .clock-label::before{
      content:"";display:inline-block;width:6px;height:6px;border-radius:50%;
      background:#bfc5d8;margin-right:6px;vertical-align:1px;
    }
    .clock-box.live .clock-label::before{
      background:#2ec28a;box-shadow:0 0 0 3px rgba(46,194,138,.18);
    }
    .clock-time{
      font-size:15px;font-weight:800;color:var(--text);letter-spacing:-.01em;
      font-variant-numeric:tabular-nums;
    }

    /* 상단 아이콘 버튼 */
    .top-icon{
      position:relative;flex:none;
      width:50px;height:50px;border-radius:13px;cursor:pointer;
      border:1px solid var(--card-line);background:#fff;color:#6b7290;
      display:grid;place-items:center;
      box-shadow:0 4px 12px rgba(27,31,51,.06);
      transition:transform .12s ease, border-color .15s, color .15s, background .15s;
    }
    .top-icon svg{width:22px;height:22px;display:block}
    .top-icon:hover{color:var(--blue);border-color:rgba(47,107,255,.5);background:#f7f9ff}
    .top-icon.danger:hover{color:var(--pink);border-color:rgba(255,77,141,.5);background:#fff5f8}
    .top-icon:active{transform:scale(.94)}
    .top-icon:focus-visible{outline:3px solid var(--blue);outline-offset:2px}
    .top-icon:disabled{opacity:.4;cursor:not-allowed}

    /* 추첨 버튼 */
    .draw-btn{
      appearance:none;cursor:pointer;font-family:inherit;flex:none;
      height:50px;min-width:128px;padding:0 26px;
      font-size:16px;font-weight:800;letter-spacing:-.01em;border-radius:13px;
      display:inline-flex;align-items:center;justify-content:center;
      border:0;color:#fff;
      background:linear-gradient(105deg,var(--blue),#7a5cff 45%,var(--pink) 100%);
      background-size:200% 100%;
      box-shadow:0 10px 24px rgba(47,107,255,.3);
      transition:transform .12s ease, filter .2s ease, background-position .6s ease;
    }
    .draw-btn:hover{filter:brightness(1.06);background-position:100% 0}
    .draw-btn:active{transform:scale(.97)}
    .draw-btn:disabled{filter:grayscale(.4) brightness(.95);cursor:not-allowed}
    .draw-btn:focus-visible{outline:3px solid var(--blue);outline-offset:3px}

    /* 공통 hover 툴팁 */
    [data-tip]{position:relative}
    [data-tip]::after{
      content:attr(data-tip);
      position:absolute;top:calc(100% + 9px);left:50%;
      transform:translateX(-50%) translateY(-3px);
      background:#1b1f33;color:#fff;font-size:12px;font-weight:600;line-height:1;
      white-space:nowrap;padding:7px 10px;border-radius:8px;
      opacity:0;pointer-events:none;
      transition:opacity .14s ease, transform .14s ease;
      z-index:70;box-shadow:0 6px 18px rgba(0,0,0,.2);
    }
    [data-tip]::before{
      content:"";position:absolute;top:calc(100% + 3px);left:50%;
      transform:translateX(-50%);
      border:5px solid transparent;border-bottom-color:#1b1f33;
      opacity:0;pointer-events:none;transition:opacity .14s ease;z-index:70;
    }
    [data-tip]:hover::after{opacity:1;transform:translateX(-50%) translateY(0)}
    [data-tip]:hover::before{opacity:1}

    /* ── 레이아웃 ───────────────────────────── */
    .wrap{max-width:1180px;margin:0 auto;padding:26px 22px 90px}
    .grid{
      display:grid;gap:18px;
      grid-template-columns:repeat(auto-fill,minmax(330px,1fr));
    }

    /* ── 영역 카드 ─────────────────────────── */
    .area{
      position:relative;
      border:1px solid var(--card-line);
      background:var(--card);
      border-radius:18px;
      padding:18px 18px 20px;
      display:flex;flex-direction:column;gap:14px;
      box-shadow:0 6px 20px rgba(27,31,51,.06);
      transition:border-color .25s ease, box-shadow .25s ease, transform .25s ease;
    }
    .area.rolling{
      border-color:rgba(47,107,255,.6);
      box-shadow:0 0 0 3px rgba(47,107,255,.16),0 8px 26px rgba(47,107,255,.18);
    }
    .area.done{
      border-color:rgba(255,159,28,.7);
      box-shadow:0 0 0 3px rgba(255,159,28,.2),0 8px 28px rgba(255,159,28,.2);
    }

    .area-head{display:flex;align-items:center;gap:8px}
    .title-input{
      flex:1;min-width:0;
      font-family:inherit;font-weight:800;font-size:18px;color:var(--text);
      background:transparent;border:0;border-bottom:2px solid transparent;
      padding:4px 2px;letter-spacing:-.02em;
    }
    .title-input::placeholder{color:var(--muted);font-weight:700}
    .title-input:focus{outline:none;border-bottom-color:var(--blue)}
    .title-input:read-only{cursor:default}

    .icon-btn{
      flex:none;width:30px;height:30px;border-radius:9px;cursor:pointer;
      border:1px solid var(--card-line);background:#fafbfe;
      color:var(--muted);font-size:15px;line-height:1;
      display:grid;place-items:center;transition:.15s;
    }
    .icon-btn.reset:hover:not(:disabled){color:var(--blue);border-color:rgba(47,107,255,.5);background:#eef3ff}
    .icon-btn.del:hover:not(:disabled){color:var(--pink);border-color:rgba(255,77,141,.5);background:#fff2f6}
    .icon-btn:focus-visible{outline:2px solid var(--blue);outline-offset:2px}
    .icon-btn:disabled{opacity:.35;cursor:not-allowed}

    /* 후보 이름 라벨 줄 */
    .field-head{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:7px}
    .label{font-size:14px;color:var(--text);font-weight:700}
    .count{color:var(--muted);font-size:14px;font-weight:600}
    .count b{font-weight:800;color:var(--blue);font-size:18px;margin:0 1px;letter-spacing:-.02em}

    .names{
      width:100%;min-height:148px;resize:vertical;
      font-family:inherit;font-size:16.5px;line-height:1.75;color:var(--text);
      background:var(--field);border:1px solid var(--card-line);border-radius:11px;
      padding:12px 14px;
      scrollbar-width:thin;
      scrollbar-color:#c2c9de transparent;
    }
    .names::placeholder{color:#b3b8cc}
    .names:focus{outline:none;border-color:var(--blue);background:#fff}
    .names::-webkit-scrollbar{width:12px}
    .names::-webkit-scrollbar-track{background:transparent}
    .names::-webkit-scrollbar-thumb{
      background:#c8cee2;border-radius:10px;
      border:3px solid var(--field);background-clip:padding-box;
    }
    .names:focus::-webkit-scrollbar-thumb{border-color:#fff}
    .names::-webkit-scrollbar-thumb:hover{background:var(--blue);background-clip:padding-box}
    .names:read-only{cursor:default;opacity:.9}

    /* 추첨할 인원 줄 */
    .pick-row{
      display:flex;align-items:center;justify-content:center;gap:14px;
      padding:4px 0 2px;
    }
    .pick-label{font-size:16px;font-weight:700;color:var(--text)}

    .stepper{display:flex;align-items:center;gap:0}
    .step-btn{
      width:42px;height:42px;cursor:pointer;
      border:1px solid var(--card-line);background:#fafbfe;
      color:var(--text);font-size:24px;font-weight:700;line-height:1;
      display:grid;place-items:center;transition:.15s;
    }
    .step-btn:first-of-type{border-radius:11px 0 0 11px}
    .step-btn:last-of-type{border-radius:0 11px 11px 0}
    .step-btn:hover:not(:disabled){background:rgba(47,107,255,.1);color:var(--blue)}
    .step-btn:active:not(:disabled){transform:scale(.92)}
    .step-btn:focus-visible{outline:2px solid var(--blue);outline-offset:1px;z-index:1}
    .step-btn:disabled{opacity:.4;cursor:not-allowed}
    .step-input{
      width:62px;height:42px;text-align:center;
      font-family:inherit;font-size:21px;font-weight:800;color:var(--text);letter-spacing:-.02em;
      background:#fff;border:1px solid var(--card-line);border-left:0;border-right:0;
      -moz-appearance:textfield;
    }
    .step-input::-webkit-outer-spin-button,
    .step-input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0}
    .step-input:focus{outline:none;background:rgba(47,107,255,.06)}
    .step-input:disabled{opacity:.55;cursor:not-allowed;background:#f3f4f8}

    /* 잠긴 영역 표시 */
    .area.locked .names,
    .area.locked .title-input{background:#f3f4f8}

    /* 결과 영역 */
    .result{
      min-height:66px;border-radius:12px;
      border:1px dashed var(--card-line);
      padding:10px;
      display:flex;flex-wrap:wrap;gap:9px;align-items:center;justify-content:center;
      background:#fafbfe;
    }
    .result.empty::before{content:"추첨 대기 중";color:#b3b8cc;font-size:13px;font-weight:600}

    .chip{
      font-family:inherit;font-weight:800;font-size:22px;letter-spacing:-.02em;
      padding:9px 18px;border-radius:11px;
      color:#fff;
      background:linear-gradient(120deg,var(--amber),#ff7a45);
      box-shadow:0 6px 16px rgba(255,122,69,.32);
      white-space:nowrap;
    }
    .chip.rolling{
      color:var(--blue);
      background:#eef3ff;
      box-shadow:none;border:1px solid rgba(47,107,255,.4);
      font-variant-numeric:tabular-nums;
    }
    .chip.pop{animation:pop .42s cubic-bezier(.2,1.4,.4,1)}

    /* 영역 추가 버튼 */
    .add-area{
      min-height:120px;border-radius:18px;cursor:pointer;
      border:2px dashed var(--card-line);background:rgba(255,255,255,.5);
      color:var(--muted);font-family:inherit;font-size:15px;font-weight:700;
      display:grid;place-items:center;transition:.2s;
    }
    .add-area:hover{border-color:var(--blue);color:var(--blue);background:rgba(47,107,255,.06)}
    .add-area:focus-visible{outline:3px solid var(--blue);outline-offset:2px}
    .add-area .plus{font-size:26px;display:block;margin-bottom:4px;font-weight:400}

    .hint{
      text-align:center;color:var(--muted);font-size:12.5px;
      margin:26px auto 0;line-height:1.7;
    }

    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}
    @keyframes pop{0%{transform:scale(.4);opacity:0}60%{transform:scale(1.12)}100%{transform:scale(1);opacity:1}}

    @media (prefers-reduced-motion:reduce){
      *{animation:none!important;transition:none!important}
    }
    @media (max-width:600px){
      .draw-btn{flex:1}
      .clock-box{flex:1 1 100%;flex-direction:row;align-items:center;justify-content:space-between}
      .grid{grid-template-columns:1fr}
    }

    /* 이미지 저장 시 숨길 컨트롤 (시간은 증빙용으로 남김) */
    body.capturing .add-area,
    body.capturing .icon-btn,
    body.capturing .draw-btn,
    body.capturing .top-icon,
    body.capturing .hint{display:none!important}
  </style>
</head>
<body>

  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <span class="badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 3h5v5"/><path d="M21 3 4 20"/>
            <path d="M21 16v5h-5"/><path d="m15 15 6 6"/><path d="m4 4 5 5"/>
          </svg>
        </span>
        <div>
          <h1>랜덤 뽑기</h1>
          <span>여러 영역을 한 번에 추첨</span>
        </div>
      </div>
      <div class="clock-box" id="clockBox">
        <span class="clock-label" id="clockLabel">한국 표준시 불러오는 중</span>
        <span class="clock-time" id="clock">—</span>
      </div>
      <input type="file" id="fileInput" accept=".json,application/json" hidden onchange="handleFile(event)">
      <button class="top-icon" data-tip="내 PC에서 명단 불러오기" aria-label="내 PC에서 명단 불러오기" onclick="importData()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 14l1.45-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.55 6a2 2 0 0 1-1.94 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.93a2 2 0 0 1 1.66.9l.82 1.2a2 2 0 0 0 1.66.9H18a2 2 0 0 1 2 2v2"/>
        </svg>
      </button>
      <button class="top-icon" data-tip="명단을 내 PC에 저장 (JSON)" aria-label="명단을 내 PC에 저장" onclick="exportData()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <path d="M17 21v-8H7v8"/><path d="M7 3v5h8"/>
        </svg>
      </button>
      <button class="top-icon" id="saveImg" data-tip="화면을 내 PC에 이미지로 저장 (PNG)" aria-label="화면을 내 PC에 이미지로 저장" onclick="saveImage()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect width="18" height="18" x="3" y="3" rx="2"/><circle cx="9" cy="9" r="2"/>
          <path d="m21 15-3.09-3.09a2 2 0 0 0-2.82 0L6 21"/>
        </svg>
      </button>
      <button class="top-icon danger" id="resetAll" data-tip="전체 초기화" aria-label="전체 초기화" onclick="resetAll()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>
        </svg>
      </button>
      <button class="draw-btn" id="drawAll" onclick="drawAll()">추첨하기</button>
    </div>
  </header>

  <main class="wrap">
    <div class="grid" id="grid">
      <button class="add-area" id="addArea" onclick="addArea()">
        <span class="plus">＋</span>영역 추가
      </button>
    </div>
    <p class="hint">입력한 정보는 서버로 전송·수집되지 않습니다. 저장하기를 누를 때만 내 PC에 파일로 저장됩니다.</p>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <script>
    let seq = 0;
    let busy = false;

    /* ── 영역 생성 ─────────────────────────── */
    function createArea(title){
      const id = 'a' + (++seq);
      const grid = document.getElementById('grid');
      const el = document.createElement('section');
      el.className = 'area';
      el.dataset.id = id;
      el.innerHTML = `
        <div class="area-head">
          <input class="title-input" type="text" value="${title||''}"
                 spellcheck="false" autocapitalize="off" autocomplete="off"
                 placeholder="영역 이름 (예: 1모둠)" aria-label="영역 이름">
          <button class="icon-btn reset" data-tip="현재 영역 초기화" aria-label="현재 영역 초기화"
                  onclick="resetArea('${id}')">↺</button>
          <button class="icon-btn del" data-tip="현재 영역 삭제" aria-label="현재 영역 삭제"
                  onclick="removeArea('${id}')">✕</button>
        </div>
        <div>
          <div class="field-head">
            <label class="label">후보 이름</label>
            <span class="count">총 <b data-count>0</b>명</span>
          </div>
          <textarea class="names" placeholder="홍길동, 김철수&#10;이영희&#10;박민수"
                    spellcheck="false" autocapitalize="off" autocomplete="off"
                    oninput="updateCount('${id}')" aria-label="후보 이름"></textarea>
        </div>
        <div class="pick-row">
          <span class="pick-label">추첨할 인원</span>
          <div class="stepper">
            <button class="step-btn minus" aria-label="인원 줄이기" onclick="bump('${id}',-1)">−</button>
            <input class="step-input" type="number" min="1" value="1"
                   onchange="clampCount('${id}')" aria-label="추첨할 인원 수">
            <button class="step-btn plus" aria-label="인원 늘리기" onclick="bump('${id}',1)">+</button>
          </div>
        </div>
        <div class="result empty" data-result aria-live="polite"></div>
      `;
      grid.insertBefore(el, document.getElementById('addArea'));
      return el;
    }

    function removeArea(id){
      const el = document.querySelector(`[data-id="${id}"]`);
      if(!el || busy) return;
      if(el.classList.contains('locked')) return;   // 잠긴 영역은 삭제 불가
      el.remove();
    }

    function addArea(){
      if(busy) return;
      const n = document.querySelectorAll('.area').length + 1;
      createArea(n + '모둠');
    }

    /* ── 잠금 / 초기화 ─────────────────────── */
    function setLocked(el, locked){
      el.classList.toggle('locked', locked);
      el.querySelector('.names').readOnly = locked;
      el.querySelector('.title-input').readOnly = locked;
      el.querySelector('.step-input').disabled = locked;
      el.querySelectorAll('.step-btn').forEach(b => b.disabled = locked);
      el.querySelector('.icon-btn.del').disabled = locked;   // 삭제만 잠금, 초기화(↺)는 항상 가능
    }

    function resetArea(id){
      const el = document.querySelector(`[data-id="${id}"]`);
      if(!el || busy) return;
      setLocked(el, false);
      el.classList.remove('done','rolling');
      el.querySelector('.names').value = '';          // 후보 이름 비우기
      el.querySelector('.step-input').value = 1;       // 추첨 인원 1로
      el.querySelector('[data-count]').textContent = 0; // 총 N명 0으로
      const result = el.querySelector('[data-result]');
      result.className = 'result empty';
      result.innerHTML = '';
    }

    function resetAll(){
      if(busy) return;
      document.querySelectorAll('.area').forEach(el => resetArea(el.dataset.id));
    }

    /* ── 이름 파싱 & 카운트 ──────────────────── */
    function parseNames(el){
      return el.querySelector('.names').value
        .split(/[\n,]+/)
        .map(s => s.trim())
        .filter(Boolean);
    }
    function updateCount(id){
      const el = document.querySelector(`[data-id="${id}"]`);
      const list = parseNames(el);
      el.querySelector('[data-count]').textContent = list.length;
    }
    function clampCount(id){
      const el = document.querySelector(`[data-id="${id}"]`);
      const input = el.querySelector('.step-input');
      let v = parseInt(input.value,10);
      if(isNaN(v) || v < 1) v = 1;
      const max = Math.max(1, parseNames(el).length);
      if(v > max) v = max;
      input.value = v;
    }
    function bump(id, d){
      const input = document.querySelector(`[data-id="${id}"] .step-input`);
      if(input.disabled) return;
      input.value = (parseInt(input.value,10)||1) + d;
      clampCount(id);
    }

    /* ── 추첨 핵심 로직 ─────────────────────── */
    function pickWinners(list, n){
      const a = list.slice();
      for(let i=a.length-1;i>0;i--){
        const j = Math.floor(Math.random()*(i+1));
        [a[i],a[j]] = [a[j],a[i]];
      }
      return a.slice(0, n);
    }

    function drawAll(){
      if(busy) return;
      // 잠기지 않은(아직 안 뽑은) 영역만 대상
      const areas = [...document.querySelectorAll('.area')].filter(el => !el.classList.contains('locked'));
      const jobs = [];

      areas.forEach(el => {
        const list = parseNames(el);
        const result = el.querySelector('[data-result]');
        el.classList.remove('done','rolling');
        if(list.length === 0){
          result.className = 'result empty';
          result.innerHTML = '';
          return;
        }
        let n = parseInt(el.querySelector('.step-input').value,10)||1;
        n = Math.min(n, list.length);
        jobs.push({ el, winners: pickWinners(list, n), pool:list });
      });

      if(jobs.length === 0) return;

      busy = true;
      document.getElementById('drawAll').disabled = true;
      jobs.forEach(job => { setLocked(job.el, true); runArea(job); });

      const totalMs = Math.max(...jobs.map(j => j.winners.length)) * 520 + 1500;
      setTimeout(() => {
        busy = false;
        document.getElementById('drawAll').disabled = false;
        finale();
      }, totalMs);
    }

    /* ── 영역별 슬롯머신 롤링 ────────────────── */
    function runArea(job){
      const { el, winners, pool } = job;
      const result = el.querySelector('[data-result]');
      el.classList.add('rolling');
      result.className = 'result';
      result.innerHTML = '';

      const reduce = window.matchMedia('(prefers-reduced-motion:reduce)').matches;

      const chips = winners.map(() => {
        const c = document.createElement('span');
        c.className = 'chip rolling';
        c.textContent = '…';
        result.appendChild(c);
        return c;
      });

      if(reduce){
        chips.forEach((c,i)=>{ c.className='chip pop'; c.textContent=winners[i]; });
        el.classList.remove('rolling'); el.classList.add('done');
        return;
      }

      const spin = setInterval(() => {
        chips.forEach(c => {
          if(!c.dataset.locked)
            c.textContent = pool[Math.floor(Math.random()*pool.length)];
        });
      }, 70);

      chips.forEach((c, i) => {
        setTimeout(() => {
          c.dataset.locked = '1';
          c.className = 'chip pop';
          c.textContent = winners[i];
          burst(c);
          if(i === chips.length - 1){
            clearInterval(spin);
            el.classList.remove('rolling');
            el.classList.add('done');
          }
        }, 1100 + i*520);
      });
    }

    /* ── 이펙트 ─────────────────────────────── */
    function burst(node){
      if(typeof confetti !== 'function') return;
      const r = node.getBoundingClientRect();
      confetti({
        particleCount:42, spread:60, startVelocity:34, scalar:.85,
        origin:{ x:(r.left+r.width/2)/innerWidth, y:(r.top+r.height/2)/innerHeight },
        colors:['#2f6bff','#ff4d8d','#ff9f1c','#7a5cff']
      });
    }
    function finale(){
      if(typeof confetti !== 'function') return;
      const end = Date.now() + 900;
      (function frame(){
        confetti({particleCount:5,angle:60,spread:60,origin:{x:0},
          colors:['#2f6bff','#ff4d8d','#ff9f1c']});
        confetti({particleCount:5,angle:120,spread:60,origin:{x:1},
          colors:['#2f6bff','#ff4d8d','#ff9f1c']});
        if(Date.now() < end) requestAnimationFrame(frame);
      })();
    }

    /* ── 공정성용 한국 표준시 시계 ───────────── */
    let clockOffset = null;
    let clockSrc = '';

    async function fetchKST(timeoutMs){
      const ctrl = new AbortController();
      const timer = setTimeout(() => ctrl.abort(), timeoutMs || 4000);
      try{
        const res = await fetch(
          'https://timeapi.io/api/Time/current/zone?timeZone=Asia/Seoul',
          { cache:'no-store', signal:ctrl.signal });
        if(!res.ok) throw new Error('HTTP ' + res.status);
        const d = await res.json();
        const base = (d.dateTime || '').split('.')[0];
        const ms = new Date(base + '+09:00').getTime();
        if(isNaN(ms)) throw new Error('parse');
        return ms;
      } finally {
        clearTimeout(timer);
      }
    }

    function initClock(){
      fetchKST(4000)
        .then(ms => applyTime(ms, 'kst'))
        .catch(() => applyTime(Date.now(), 'local'));
      setInterval(renderClock, 1000);
    }
    function applyTime(ms, src){
      clockOffset = ms - Date.now();
      clockSrc = src;
      const box = document.getElementById('clockBox');
      const label = document.getElementById('clockLabel');
      if(src === 'kst'){ box.classList.add('live'); label.textContent = '한국 표준시 (KST)'; }
      else { box.classList.remove('live'); label.textContent = '기기 시간'; }
      renderClock();
    }
    function renderClock(){
      if(clockOffset === null) return;
      const now = new Date(Date.now() + clockOffset);
      document.getElementById('clock').textContent = now.toLocaleString('ko-KR', {
        timeZone:'Asia/Seoul',
        year:'numeric', month:'2-digit', day:'2-digit', weekday:'short',
        hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:false
      });
    }

    /* ── 페이지를 이미지로 저장 ───────────────── */
    function stamp(){
      const d = new Date(), p = n => String(n).padStart(2,'0');
      return `${p(d.getMonth()+1)}${p(d.getDate())}_${p(d.getHours())}${p(d.getMinutes())}`;
    }
    async function saveImage(){
      if(typeof html2canvas !== 'function'){
        alert('이미지 저장 기능을 불러오지 못했어. 잠시 후 다시 시도해줘.');
        return;
      }
      const btn = document.getElementById('saveImg');
      btn.disabled = true;
      document.body.classList.add('capturing');
      try{
        const canvas = await html2canvas(document.body, {
          backgroundColor:'#eef1f8',
          scale:2, useCORS:true,
          windowWidth:document.documentElement.scrollWidth
        });
        const link = document.createElement('a');
        link.download = `랜덤뽑기_${stamp()}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
      }catch(err){
        alert('이미지를 만드는 중 문제가 생겼어: ' + err.message);
      }finally{
        document.body.classList.remove('capturing');
        btn.disabled = false;
      }
    }

    /* ── 명단 저장(JSON) / 불러오기 ───────────── */
    function exportData(){
      const areas = [...document.querySelectorAll('.area')].map(el => ({
        title: el.querySelector('.title-input').value,
        names: el.querySelector('.names').value,
        pick: parseInt(el.querySelector('.step-input').value,10) || 1
      }));
      const data = { app:'random-picker', version:1, savedAt:new Date().toISOString(), areas };
      const blob = new Blob([JSON.stringify(data, null, 2)], { type:'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `랜덤뽑기_명단_${stamp()}.json`;
      a.click();
      URL.revokeObjectURL(url);
    }

    function importData(){
      if(busy) return;
      document.getElementById('fileInput').click();
    }
    function handleFile(e){
      const file = e.target.files[0];
      if(!file) return;
      const reader = new FileReader();
      reader.onload = ev => {
        try{
          const data = JSON.parse(ev.target.result);
          if(!data || !Array.isArray(data.areas)) throw new Error('형식이 올바르지 않아');
          loadAreas(data.areas);
        }catch(err){
          alert('파일을 불러오지 못했어: ' + err.message);
        }
      };
      reader.readAsText(file);
      e.target.value = '';   // 같은 파일 다시 선택 가능하도록 초기화
    }
    function loadAreas(arr){
      if(busy) return;
      // 기존 영역을 모두 비우고 파일 내용으로 교체
      document.querySelectorAll('.area').forEach(el => el.remove());
      if(arr.length === 0){ createArea('1모둠'); return; }
      arr.forEach(a => {
        const el = createArea(a.title || '');
        el.querySelector('.names').value = a.names || '';
        el.querySelector('.step-input').value = parseInt(a.pick,10) || 1;
        updateCount(el.dataset.id);
        clampCount(el.dataset.id);
      });
    }

    /* ── 초기화 ─────────────────────────────── */
    createArea('1모둠');
    initClock();
  </script>
</body>
</html>
